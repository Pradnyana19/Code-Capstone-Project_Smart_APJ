// =======================================================
// TASK 1: MONITORING SENSOR, TIME SYNC, DISPLAY, & IOT (Core 0)
// =======================================================
void fungsiTaskSensor(void *pvParameters) {
  int localKecerahan = 0;
  int localJam = 12;
  int localMenit = 0;
  
  for(;;) {
    // 1. SINKRONISASI WAKTU (NTP Terlebih Dahulu, Backup ke GPS)
    struct tm timeinfo;
    if (getLocalTime(&timeinfo, 10)) { 
      localJam = timeinfo.tm_hour;
      localMenit = timeinfo.tm_min;
    } 
    else {
      while (SerialGPS.available() > 0) {
        gps.encode(SerialGPS.read());
      }
      if (gps.time.isValid()) {
        int gpsJam = gps.time.hour() + 8; // Konversi ke WITA
        if (gpsJam >= 24) gpsJam -= 24;
        localJam = gpsJam;
        localMenit = gps.time.minute();
      }
    }

    // Simpan data jam dan menit terbaru ke variabel global secara aman
    if (xSemaphoreTake(xSistemMutex, pdMS_TO_TICKS(50)) == pdTRUE) {
      jamSekarang = localJam;
      menitSekarang = localMenit;
      localKecerahan = kecerahanTarget; 
      xSemaphoreGive(xSistemMutex);
    }

    // 2. Pembacaan Sensor Listrik PZEM
    float tegangan = pzem.voltage();
    float arus     = pzem.current();
    float daya     = pzem.power();
    
    if (isnan(tegangan)) { tegangan = 0.0; }
    if (isnan(arus))     { arus = 0.0; }
    if (isnan(daya))     { daya = 0.0; }

    // 3. Pembacaan Dua Sensor LDR
    int ldrVal1 = analogRead(LDR1_PIN);
    int ldrVal2 = analogRead(LDR2_PIN);

    // 4. Implementasi Logika Status Validasi Gangguan
    int status1 = 0; 
    String statusString = "0";
    
    if (localKecerahan > 0) {
      if (arus <= 0.02 && (ldrVal1 > 3000 || ldrVal2 > 3000)) {
        status1 = 2; // RUSAK
        statusString = "2";
      } else {
        status1 = 1; // NYALA NORMAL
        statusString = "1";
      }
    } else {
      status1 = 0; // STANDBY SIANG
      statusString = "0";
    }

    // 5. Update LCD - Menampilkan Arus, Tegangan, dan Daya saja
    lcd.setCursor(0, 0);
    lcd.print("V:"); lcd.print(tegangan, 1); lcd.print("V ");
    lcd.setCursor(9, 0);
    lcd.print("I:"); lcd.print(arus, 2); lcd.print("A");

    lcd.setCursor(0, 1);
    lcd.print("Daya: "); lcd.print(daya, 1); lcd.print(" Watt   "); 

    // 6. Kirim Serial Data Telemetri untuk Monitoring Lokal
    Serial.printf("[TELEMETRI] Jam: %02d:%02d | V: %.1fV | I: %.2fA | P: %.1fW\n", localJam, localMenit, tegangan, arus, daya);
    Serial.printf("[ANALISIS LDR] LDR1: %d | LDR2: %d | Status Kode: %s\n", ldrVal1, ldrVal2, statusString.c_str());

    // 7. PENGIRIMAN DATA KE CLOUD & MANAGEMENT REKONEKSI WIFI
    if (WiFi.status() == WL_CONNECTED) {
      
      String myLatitude = "0.000000";
      String myLongitude = "0.000000";
      if (gps.location.isValid()) {
        myLatitude = String(gps.location.lat(), 6);
        myLongitude = String(gps.location.lng(), 6);
      }

      // --- TRANSMISI 1: THINGSPEAK (Setiap 30 Detik) ---
      if ((millis() - lastTimeThingSpeak) > delayThingSpeak) {
        HTTPClient httpTS;
        String urlPath = String(serverName) + "?api_key=" + apiKey + 
                         "&field1=" + String(daya) +      
                         "&field2=" + String(tegangan) +  
                         "&field3=" + String(arus) +      
                         "&field4=" + String(status1) +    
                         "&field5=" + myLatitude +        
                         "&field6=" + myLongitude;        
        
        httpTS.begin(urlPath);
        int httpResponseCodeTS = httpTS.GET();
        if (httpResponseCodeTS > 0) {
           Serial.printf("[ThingSpeak] Terkirim. Respon: %d\n", httpResponseCodeTS);
        } else {
           Serial.printf("[ThingSpeak] Gagal. Error: %s\n", httpTS.errorToString(httpResponseCodeTS).c_str());
        }
        httpTS.end();
        lastTimeThingSpeak = millis();
      }

      // --- TRANSMISI 2: GOOGLE SPREADSHEET (Setiap 10 Detik) ---
      if ((millis() - lastTimeSpreadsheet) > delaySpreadsheet) {
        HTTPClient httpSheets;
        
        String urlSheets = "https://script.google.com/macros/s/" + googleScriptDeploymentId + "/exec" +
                           "?daya=" + String(daya) +
                           "&tegangan=" + String(tegangan) +
                           "&arus=" + String(arus) +
                           "&status=" + status1;
        
        httpSheets.begin(urlSheets);
        httpSheets.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
        
        int httpResponseCodeSheets = httpSheets.GET();
        if (httpResponseCodeSheets > 0) {
           Serial.printf("[Spreadsheet] Berhasil Terkirim. Respon Server: %d\n", httpResponseCodeSheets);
        } else {
           Serial.printf("[Spreadsheet] Gagal Mengirim. Error: %s\n", httpSheets.errorToString(httpResponseCodeSheets).c_str());
        }
        httpSheets.end();
        lastTimeSpreadsheet = millis();
      }

    } else {
      // PERBAIKAN REKONEKSI WIFI (NON-BLOCKING):
      // Jika koneksi putus, coba hubungkan kembali setiap interval 10 detik tanpa menggunakan fungsi delay() pembatas.
      if ((millis() - lastTimeReconnectWiFi) > delayReconnectWiFi) {
        Serial.println(F("[SISTEM] Wi-Fi terputus! Mencoba menghubungkan kembali..."));
        WiFi.disconnect();
        WiFi.begin(ssid, password);
        lastTimeReconnectWiFi = millis();
      }
    }

    vTaskDelay(pdMS_TO_TICKS(2000));
  }
}

// =======================================================
// TASK 2: KENDALI OTOMATIS BERBASIS WAKTU & SERIAL OVERRIDE (Core 1)
// =======================================================
void fungsiTaskKendali(void *pvParameters) {
  String inputBuffer = "";
  bool modeManual = false;
  int localJam = 12;
  int localMenit = 0;
  
  for(;;) {
    // 1. Cek Perintah Manual Dari Serial Monitor (Override)
    while (Serial.available() > 0) {
      char c = Serial.read();
      if (c == '\n' || c == '\r') {
        if (inputBuffer.length() > 0) {
          if (inputBuffer == "auto") {
            modeManual = false;
            Serial.println(F("\n[SISTEM] -> KEMBALI KE MODE OTOMATISASI JADWAL JAM"));
          } else {
            int inputUser = inputBuffer.toInt();
            if (inputUser >= 0 && inputUser <= 100) {
              modeManual = true;
              if (xSemaphoreTake(xSistemMutex, pdMS_TO_TICKS(10)) == pdTRUE) {
                kecerahanTarget = inputUser;
                xSemaphoreGive(xSistemMutex);
              }
              
              if (inputUser == 0) {
                digitalWrite(RELAY_PIN, LOW);  
                acDimmer.setPower(0);          
                acDimmer.setState(OFF);        
                Serial.println(F("\n[MANUAL] -> RELAY OFF, DIMMER 0%"));
              } else {
                digitalWrite(RELAY_PIN, HIGH); 
                acDimmer.setState(ON);         
                acDimmer.setPower(inputUser);
                Serial.printf("[MANUAL] -> KENDALI PAKSA %d%% (Ketik 'auto' untuk mengembalikan)\n", inputUser);
              }
            }
          }
          inputBuffer = ""; 
        }
      } else if (isDigit(c) || c == 'a' || c == 'u' || c == 't' || c == 'o') {
        inputBuffer += c; 
      }
    }

    // 2. JIKA MODE OTOMATIS (Penjadwalan Khusus Dokumentasi)
    if (!modeManual) {
      if (xSemaphoreTake(xSistemMutex, pdMS_TO_TICKS(10)) == pdTRUE) {
        localJam = jamSekarang;
        localMenit = menitSekarang;
        xSemaphoreGive(xSistemMutex);
      }

      int totalMenit = (localJam * 60) + localMenit;
      
      int batasMulaiTerang = (18 * 60) + 0; // 21:15 -> 1275 menit
      int batasMulaiRedup  = (23 * 60) + 59; // 21:25 -> 1285 menit
      int batasSelesaiMalam = (6 * 60);      // 06:00 -> 360 menit

      // Kondisi A: Jam 21:15 sampai 21:24
      if (totalMenit >= batasMulaiTerang && totalMenit < batasMulaiRedup) {
        digitalWrite(RELAY_PIN, HIGH); 
        acDimmer.setState(ON);
        acDimmer.setPower(97); 

        if (xSemaphoreTake(xSistemMutex, pdMS_TO_TICKS(10)) == pdTRUE) {
          kecerahanTarget = 100; 
          xSemaphoreGive(xSistemMutex);
        }
      } 
      // Kondisi B: Jam 21:25 sampai 05:59 Pagi
      else if (totalMenit >= batasMulaiRedup || totalMenit < batasSelesaiMalam) {
        digitalWrite(RELAY_PIN, HIGH); 
        acDimmer.setState(ON);
        acDimmer.setPower(60); 

        if (xSemaphoreTake(xSistemMutex, pdMS_TO_TICKS(10)) == pdTRUE) {
          kecerahanTarget = 60; 
          xSemaphoreGive(xSistemMutex);
        }
      } 
      // Kondisi C: Sisa Waktu Lainnya (06:00 pagi sampai 21:14 malam) -> MATI TOTAL
      else {
        digitalWrite(RELAY_PIN, LOW); 
        acDimmer.setPower(0);
        acDimmer.setState(OFF);

        if (xSemaphoreTake(xSistemMutex, pdMS_TO_TICKS(10)) == pdTRUE) {
          kecerahanTarget = 0;
          xSemaphoreGive(xSistemMutex);
        }
      }
    }

    vTaskDelay(pdMS_TO_TICKS(20));
  }
}

// =======================================================
// SETUP & INITIALIZATION
// =======================================================
void setup() {
  Serial.begin(115200);
  SerialGPS.begin(9600, SERIAL_8N1, ESP32_RX1_GPS, ESP32_TX1_GPS);
  while(!Serial) { ; } 
  
  xSistemMutex = xSemaphoreCreateMutex();
  
  pinMode(RELAY_PIN, OUTPUT);
  digitalWrite(RELAY_PIN, LOW);
  
  Wire.begin(LCD_SDA_PIN, LCD_SCL_PIN);
  lcd.init();
  lcd.backlight();
  
  lcd.setCursor(0, 0); lcd.print("  SMART PJU IoT ");
  lcd.setCursor(0, 1); lcd.print("CONNECTING WIFI ");
  
  acDimmer.begin(NORMAL_MODE, ON);
  acDimmer.setPower(0);
  acDimmer.setState(OFF);
  
  WiFi.begin(ssid, password);
  int timeout_counter = 0;
  while (WiFi.status() != WL_CONNECTED && timeout_counter < 20) {
    delay(500);
    Serial.print(".");
    timeout_counter++;
  }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println(F("\n>> Wi-Fi Terhubung Sukses!"));
    lcd.setCursor(0, 1); lcd.print("WIFI CONNECTED  ");
    configTime(gmtOffset_sec, daylightOffset_sec, ntpServer);
  } else {
    Serial.println(F("\n>> Wi-Fi Offline (Mengandalkan Waktu GPS)"));
    lcd.setCursor(0, 1); lcd.print("WIFI OFFLINE    ");
  }
  
  delay(1500); 
  lcd.clear();
  
  Serial.println(F("\n============================================="));
  Serial.println(F("   SISTEM KENDALI UTAMA BERHASIL DIALIRKAN   "));
  Serial.println(F("============================================="));

  xTaskCreatePinnedToCore(fungsiTaskSensor, "TaskSensorDisplay", 8192, NULL, 1, &TaskSensorDisplay, 0);
  xTaskCreatePinnedToCore(fungsiTaskKendali, "TaskKendaliDimmer", 4096, NULL, 2, &TaskKendaliDimmer, 1);
}

void loop() {
  vTaskDelete(NULL); 
}
