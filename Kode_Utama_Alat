/*
 * PROYEK: Smart PJU Berbasis FreeRTOS (Multi-Core ESP32) - MODE KENDALI MANUAL
 * KONEKSI PIN:
 * - Relay IN       : Pin 13
 * - Dimmer PWM/PSM : Pin 14
 * - Dimmer ZC      : Pin 32
 * - LDR 1          : Pin 15 (Monitoring Status)
 * - LDR 2          : Pin 35 (Monitoring Status)
 * - PZEM RX        : Pin D2 (Terhubung ke ESP32 TX2 / GPIO 2)
 * - PZEM TX        : Pin D4 (Terhubung ke ESP32 RX2 / GPIO 4)
 * - GPS RX         : Pin 25 (Terhubung ke ESP32 TX1)
 * - GPS TX         : Pin 26 (Terhubung ke ESP32 RX1)
 * - LCD SDA        : Pin 21 
 * - LCD SCL        : Pin 22 
 */

#include <PZEM004Tv30.h>
#include <Wire.h>              
#include <LiquidCrystal_I2C.h> 
#include <RBDdimmer.h>
#include <TinyGPSPlus.h>
#include <WiFi.h>
#include <HTTPClient.h>
#include <time.h>

// ================= KONFIGURASI WIFI & THINGSPEAK =================
const char* ssid       = "NAMA_WIFI_ANDA";
const char* password   = "PASSWORD_WIFI";
String apiKey          = "Q5NO77H68QGKDZ7S"; // Pastikan ini Write API Key Anda
const char* serverName = "http://api.thingspeak.com/update";

// ================= KONFIGURASI WAKTU (NTP) =================
const char* ntpServer  = "pool.ntp.org";
const long  gmtOffset_sec = 28800; // GMT+8 (WITA)
const int   daylightOffset_sec = 0;

// ================= DEKLARASI PIN HARDWARE =================
#define RELAY_PIN 13
#define DIMMER_PIN 14
#define ZC_PIN 32

#define LDR1_PIN 15 
#define LDR2_PIN 35 

#define ESP32_RX2_PZEM 4  // D4 
#define ESP32_TX2_PZEM 2  // D2 

#define ESP32_RX1_GPS 26 
#define ESP32_TX1_GPS 25 

#define LCD_SDA_PIN 21 
#define LCD_SCL_PIN 22

// Inisialisasi Objek Hardware
PZEM004Tv30 pzem(Serial2, ESP32_RX2_PZEM, ESP32_TX2_PZEM); 
HardwareSerial SerialGPS(1); 
TinyGPSPlus gps;
LiquidCrystal_I2C lcd(0x27, 16, 2); 
dimmerLamp acDimmer(DIMMER_PIN, ZC_PIN);

// Variabel Global (Gunakan volatile karena diakses antar Core/Task)
volatile int kecerahanTarget = 0; 
volatile int statusLampu = 0; // 0: Siang/Mati, 1: Normal, 2: Rusak
volatile int jamSekarang = 12;

unsigned long lastTimeThingSpeak = 0;
unsigned long delayThingSpeak = 20000; 

// Deklarasi Task Handle FreeRTOS
TaskHandle_t TaskSensorWiFi;
TaskHandle_t TaskKendaliDimmer;

// =======================================================
// TASK 1: BACA SENSOR, LCD & KIRIM THINGSPEAK (Di Core 0)
// =======================================================
void fungsiTaskSensor(void *pvParameters) {
  for(;;) {
    // 1. Sinkronisasi Waktu dari NTP (Masih dipertahankan untuk referensi data)
    struct tm timeinfo;
    if (getLocalTime(&timeinfo, 10)) { 
      jamSekarang = timeinfo.tm_hour;
    } 
    else {
      while (SerialGPS.available() > 0) {
        gps.encode(SerialGPS.read());
      }
      if (gps.time.isValid()) {
        int gpsJam = gps.time.hour() + 8; // Konversi ke WITA
        if (gpsJam >= 24) gpsJam -= 24;
        jamSekarang = gpsJam;
      }
    }

    // 2. Baca Data Elektrik PZEM
    float tegangan = pzem.voltage();
    float arus     = pzem.current();
    float daya     = pzem.power();
    
    if (isnan(tegangan)) { tegangan = 0.0; }
    if (isnan(arus))     { arus = 0.0; }
    if (isnan(daya))     { daya = 0.0; }

    // Baca 2 Buah Sensor LDR untuk Monitoring
    int nilaiLDR1 = analogRead(LDR1_PIN);
    int nilaiLDR2 = analogRead(LDR2_PIN);

    // 3. Logika Validasi Gangguan Ganda
    if (kecerahanTarget > 0) {
      if (arus <= 0.02 || nilaiLDR1 > 3000 || nilaiLDR2 > 3000) {
        statusLampu = 2; // RUSAK
      } else {
        statusLampu = 1; // NYALA NORMAL
      }
    } else {
      statusLampu = 0; // STANDBY (Target 0%)
    }

    // 4. Tampilan LCD Fokus Parameter Listrik
    lcd.setCursor(0, 0);
    lcd.print("V:"); lcd.print(tegangan, 1); lcd.print("V ");
    lcd.setCursor(9, 0);
    lcd.print("I:"); lcd.print(arus, 2); lcd.print("A");

    lcd.setCursor(0, 1);
    lcd.print("D: "); lcd.print(daya, 1); lcd.print("W ");
    lcd.setCursor(10, 1);
    lcd.print("L:"); lcd.print(kecerahanTarget); lcd.print("%  "); // Menampilkan status Dimmer di LCD

    // 5. Pengiriman Data Berkala ke ThingSpeak
    if ((millis() - lastTimeThingSpeak) > delayThingSpeak) {
      if(WiFi.status() == WL_CONNECTED){
        
        String myLatitude = "0.000000";
        String myLongitude = "0.000000";
        if (gps.location.isValid()) {
          myLatitude = String(gps.location.lat(), 6);
          myLongitude = String(gps.location.lng(), 6);
        }

        HTTPClient http;
        String urlPath = String(serverName) + "?api_key=" + apiKey + 
                         "&field1=" + String(daya) +       
                         "&field2=" + String(tegangan) +   
                         "&field3=" + String(arus) +       
                         "&field4=" + String(statusLampu)+ 
                         "&field5=" + myLatitude +         
                         "&field6=" + myLongitude;         
        
        http.begin(urlPath);
        int httpResponseCode = http.GET();
        if(httpResponseCode > 0){
           Serial.print("[ThingSpeak] Terkirim. Kode: ");
           Serial.println(httpResponseCode);
        } else {
           Serial.print("[ThingSpeak] Gagal. Kode: ");
           Serial.println(httpResponseCode);
        }
        http.end(); 
      }
      lastTimeThingSpeak = millis();
    }

    vTaskDelay(1000 / portTICK_PERIOD_MS);
  }
}

// =======================================================
// TASK 2: KENDALI DIMMER MANUAL DARI SERIAL (Di Core 1)
// =======================================================
void fungsiTaskKendali(void *pvParameters) {
  int kecerahanSaatIni = -1; // Pelacak status hardware agar tidak dieksekusi berulang-ulang

  for(;;) {
    // 1. Baca Input dari Serial Monitor (0 - 100)
    if (Serial.available() > 0) {
      int inputUser = Serial.parseInt();

      // Bersihkan sisa karakter enter (newline) di buffer
      while (Serial.available() > 0) {
        Serial.read();
      }

      if (inputUser >= 0 && inputUser <= 100) {
        kecerahanTarget = inputUser;
        Serial.print(">> PERINTAH DITERIMA: Target Dimmer = ");
        Serial.print(kecerahanTarget);
        Serial.println("%");
      }
    }

    // 2. Eksekusi Perubahan Hardware HANYA JIKA target berubah
    if (kecerahanTarget != kecerahanSaatIni) {
      if (kecerahanTarget == 0) {
        digitalWrite(RELAY_PIN, LOW); // Putus Relay
        acDimmer.setPower(0);
        acDimmer.setState(OFF);       // Kunci TRIAC padam total
      } 
      else {
        digitalWrite(RELAY_PIN, HIGH); // Nyalakan Relay
        acDimmer.setState(ON);

        // Trik Anti-Flicker untuk kecerahan 100%
        if (kecerahanTarget == 100) {
          acDimmer.setPower(95); 
        } else {
          acDimmer.setPower(kecerahanTarget);
        }
      }
      // Simpan status agar hardware tidak terus-menerus diset ulang di siklus berikutnya
      kecerahanSaatIni = kecerahanTarget; 
    }

    // Jeda super singkat 20ms untuk stabilitas hardware
    vTaskDelay(20 / portTICK_PERIOD_MS);
  }
}

void setup() {
  Serial.begin(115200);
  SerialGPS.begin(9600, SERIAL_8N1, ESP32_RX1_GPS, ESP32_TX1_GPS);
  Wire.begin(LCD_SDA_PIN, LCD_SCL_PIN); 
  
  lcd.init();
  lcd.backlight();
  lcd.setCursor(0,0);
  lcd.print("  SMART PJU IoT ");
  lcd.setCursor(0,1);
  lcd.print(" Connect WiFi.. ");

  // Mencoba tersambung ke jaringan WiFi
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi Terhubung!");
  Serial.println("Ketik angka 0 - 100 di Serial Monitor untuk mengatur dimmer.");
  
  // Sinkronisasi awal waktu NTP
  configTime(gmtOffset_sec, daylightOffset_sec, ntpServer);
  lcd.clear();

  // Konfigurasi Pin Relay & Dimmer
  pinMode(RELAY_PIN, OUTPUT);
  digitalWrite(RELAY_PIN, LOW); // Default Mati
  
  acDimmer.begin(NORMAL_MODE, ON); 
  acDimmer.setPower(0);
  acDimmer.setState(OFF); // Default Mati
  
  // -----------------------------------------------------
  // DEPLOYMENT TASK KE CORE MASING-MASING
  // -----------------------------------------------------
  xTaskCreatePinnedToCore(
    fungsiTaskSensor, "TaskSensorWiFi", 15000, NULL, 1, &TaskSensorWiFi, 0                      
  );

  xTaskCreatePinnedToCore(
    fungsiTaskKendali, "TaskKendaliDimmer", 10000, NULL, 2, &TaskKendaliDimmer, 1                      
  );
}

void loop() {
  // Loop dibiarkan kosong, FreeRTOS mengambil alih
}
